# Optional — only required if TRANSCRIPTION_BACKEND=openai or TRANSLATION_BACKEND=openai
OPENAI_API_KEY=

TRANSCRIPTION_BACKEND=mlx          # mlx (Apple Silicon GPU, fast) | local (faster-whisper, CPU) | openai
TRANSLATION_BACKEND=ollama         # ollama | openai
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo   # HF repo, used when backend=mlx
LOCAL_WHISPER_MODEL=large-v3-turbo # faster-whisper model, used when backend=local (small/medium/large-v3-turbo/large-v3)
OLLAMA_MODEL=qwen2.5:14b           # qwen2.5:7b for 8GB RAM, qwen2.5:14b for 16GB+
OLLAMA_BASE_URL=http://localhost:11434
DATA_DIR=./data
WHISPER_MODE=always                # always | fallback_only
USE_ARTIFACT_CACHE=true            # reuse audio/captions/whisper per video URL on reruns
REFINEMENT_ENABLED=true            # critic/repair loop after translation
REFINEMENT_CONFIDENCE_THRESHOLD=0.7
REFINEMENT_MAX_ITERATIONS=2

# For login-required Vimeo (or private YouTube) — use ONE of:
# YTDLP_COOKIES_FROM_BROWSER=chrome   # chrome | safari | firefox | brave
# YTDLP_COOKIES_FILE=./cookies.txt    # Netscape-format cookies file
